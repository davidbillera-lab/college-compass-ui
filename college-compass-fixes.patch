-      <Text
-        position={[0, part.size[1] / 2 + 0.4, 0]}
-        fontSize={0.25}
-        color="white"
-        anchorX="center"
-        anchorY="bottom"
-        outlineWidth={0.02}
-        outlineColor="#000000"
-      >
-        {part.name}
-      </Text>
-    </mesh>
-  );
-};
